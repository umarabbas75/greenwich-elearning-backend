generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id                       String                     @id @default(uuid())
  firstName                String
  lastName                 String
  email                    String                     @unique
  phone                    String?
  photo                    String?
  photoBase64              String?
  timezone                 String?
  password                 String
  // Set true for admin-created accounts (the admin sets a temporary password).
  // The user is forced to set their own password on first login, after which it
  // is cleared. Self-registered users chose their own password, so it stays false.
  mustChangePassword       Boolean                    @default(false)
  role                     Role
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  deletedAt                DateTime?
  LastSeenSection          LastSeenSection[]
  PoliciesAndProcedures    PoliciesAndProcedures[]
  todos                    TodoItem[]
  Comment                  Comment[]
  favoriteThreads          FavoriteForumThread[]      @relation("UserFavoriteThreads")
  ForumComment             ForumComment[]
  ForumThread              ForumThread[]
  commentsMade             Notification[]             @relation("Commenter")
  Notification             Notification[]
  Post                     Post[]
  threadSubscriptions      ThreadSubscription[]       @relation("UserThreadSubscriptions")
  UserCourse               UserCourse[]
  ContactMessage           ContactMessage[]
  status                   UserStatus                 @default(inactive)
  QuizProgress             QuizProgress[]
  formCompletions          UserFormCompletion[]
  UserPolicyCompletion     UserPolicyCompletion[]
  UserPolicyItemCompletion UserPolicyItemCompletion[]
  assignmentSubmissions    AssignmentSubmission[]     @relation("StudentSubmissions")
  assignedSubmissions      AssignmentSubmission[]     @relation("AdminAssignedSubmissions")
  reviewedSubmissions      AssignmentSubmission[]     @relation("AdminReviewedSubmissions")
  assignmentsCreated       Assignment[]               @relation("AssignmentsCreatedByAdmin")
  assignmentsToReview      Assignment[]               @relation("AssignmentReviewer")
  feedbackSubmissions      CourseFeedbackSubmission[]
  assessmentsCreated       Assessment[]               @relation("AssessmentsCreatedByAdmin")
  assessmentAttempts       AssessmentAttempt[]
  courseCompletions        CourseCompletion[]
  passwordResets           PasswordReset[]
  loginEvents              LoginEvent[]
  forumViewEvents          ForumViewEvent[]
  sectionTimeSpent         SectionTimeSpent[]
  sectionTimeSpentDaily    SectionTimeSpentDaily[]
  emailLogs                EmailLog[]
  securityEvents           SecurityEvent[]
  // Last time this user's password actually changed (reset, first-login force,
  // or admin change). Null = never changed since creation. Drives the security
  // dashboard; the SecurityEvent log holds the full history.
  passwordChangedAt        DateTime?

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

/// One forgot-password attempt: a hashed OTP with a short TTL, single-use.
/// Rows are created on "request OTP", consumed on successful verify, and
/// superseded (invalidated) when a new code is requested for the same user.
model PasswordReset {
  id           String    @id @default(uuid())
  userId       String
  /// argon2 hash of the 6-digit OTP — never store the code in plaintext.
  otpHash      String
  expiresAt    DateTime
  /// Wrong-guess counter; the row is locked once it hits the max.
  attempts     Int       @default(0)
  /// How many times a code has been (re)sent for this active reset.
  resendCount  Int       @default(0)
  /// Set when the OTP is verified — gates the actual password reset.
  verifiedAt   DateTime?
  /// argon2 hash of the one-time reset token issued after verify.
  resetTokenHash String?
  /// Set when the password is actually changed — terminal, makes row unusable.
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Hot path: find the latest active reset for a user.
  @@index([userId, consumedAt, createdAt(sort: Desc)])
  @@map("password_resets")
}

enum UserStatus {
  active
  inactive
}

model Course {
  id                   String                 @id @default(uuid())
  isActive             Boolean                @default(true)
  title                String                 @unique
  description          String
  image                String
  overview             String
  duration             String
  price                String?
  assessment           String
  // Number of days a learner retains access after completing the course
  // (content completion). Access is computed live on each request; once
  // completedAt + validityDays has passed, the learner is locked out.
  // Defaults to 365 (one year) when the admin doesn't specify it.
  validityDays         Int                    @default(365)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  syllabusOverview     String
  resourcesOverview    String
  tutorInfo            String? // Tutor information (name, bio, qualifications, contact, etc.)
  assessments          Json[]
  resources            Json[]
  syllabus             Json[]
  UserCourseProgress   UserCourseProgress[]
  modules              Module[]
  Post                 Post[]
  users                UserCourse[]
  LastSeenSection      LastSeenSection[]
  courseForms          CourseForm[]
  formCompletions      UserFormCompletion[]
  Policy               Policy[]
  UserPolicyCompletion UserPolicyCompletion[]
  Assignment           Assignment[]
  feedbackForm         CourseFeedbackForm?
  feedbackSubmissions  CourseFeedbackSubmission[]
  courseAssessments    Assessment[]
  questionCategories   QuestionCategory[]
  questions            Question[]
  courseCompletions    CourseCompletion[]
  ForumThread          ForumThread[]
  forumViewEvents      ForumViewEvent[]

  @@map("courses")
}

model UserCourse {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  isActive    Boolean   @default(false) // Default status as inactive
  isPaid      Boolean   @default(false) // Default status as inactive
  // When the admin first activated this course for this user (isActive false→true).
  // This is the engagement "start line" for NEVER_STARTED reminders. Nullable for
  // historical rows; the sweep falls back to updatedAt when null.
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId]) // Ensures a user can only have one entry per course
  @@map("user_courses")
}

model CourseForm {
  id                  String               @id @default(uuid())
  courseId            String
  formId              String
  formName            String
  isRequired          Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  userFormCompletions UserFormCompletion[] @relation("FormCompletions")
  course              Course               @relation(fields: [courseId], references: [id])

  @@unique([courseId, formId])
  @@map("course_forms")
}

model UserFormCompletion {
  id           String     @id @default(uuid())
  userId       String
  courseId     String
  formId       String
  isComplete   Boolean    @default(false)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  metadata     Json? // New field for storing form metadata
  courseFormId String
  courseForm   CourseForm @relation(fields: [courseFormId], references: [id], name: "FormCompletions", onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])
  course       Course     @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId, formId])
  @@map("user_form_completions")
}

model Policy {
  id          String                 @id @default(uuid())
  title       String // e.g., "NEBOSH Course Policy", "Greenwich Course Policy"
  description String?
  courseId    String
  order       Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  course      Course                 @relation(fields: [courseId], references: [id])
  items       PolicyItem[]
  completions UserPolicyCompletion[]

  @@index([courseId]) // For finding all policies in a course
  @@map("policies")
}

model PolicyItem {
  id          String                     @id @default(uuid())
  title       String // e.g., "Safety Guidelines", "Code of Conduct"
  description String?
  link        String // URL to the document
  isRequired  Boolean                    @default(true)
  order       Int                        @default(0)
  policyId    String
  policy      Policy                     @relation(fields: [policyId], references: [id])
  completions UserPolicyItemCompletion[]

  @@index([policyId, isRequired]) // For finding required items
  @@index([policyId, order]) // For ordered display
  @@index([policyId, isRequired, order])
  @@map("policy_items")
}

model UserPolicyCompletion {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  policyId    String
  isComplete  Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  course      Course    @relation(fields: [courseId], references: [id])
  policy      Policy    @relation(fields: [policyId], references: [id])

  @@unique([userId, courseId, policyId])
  @@index([userId, courseId]) // For finding user's course completions
  @@index([policyId, isComplete]) // For checking policy completion status
  @@index([userId, policyId])
  @@map("user_policy_completions")
}

model UserPolicyItemCompletion {
  id          String     @id @default(uuid())
  userId      String
  itemId      String
  isComplete  Boolean    @default(false)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
  item        PolicyItem @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId])
  @@index([userId, itemId]) // For faster lookups
  @@index([itemId, isComplete]) // For checking completion status
  @@index([userId, isComplete]) // For finding user's completed items
  @@index([userId, itemId, isComplete])
  @@map("user_policy_item_completions")
}

model CourseFeedbackForm {
  id          String                    @id @default(uuid())
  courseId    String
  formName    String
  formStructure Json                    // The actual form questions/structure
  isRequired  Boolean                   @default(true)
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  course      Course                    @relation(fields: [courseId], references: [id])
  submissions CourseFeedbackSubmission[]

  @@unique([courseId]) // One feedback form per course
  @@map("course_feedback_forms")
}

model CourseFeedbackSubmission {
  id                    String                   @id @default(uuid())
  courseId              String
  userId                String
  feedbackFormId        String
  formVersion           String?
  responses             Json                     // formData verbatim (legacy name kept for compat)
  meanRating            Decimal?                 @db.Decimal(3, 2)
  overallRating         FeedbackOverallRating?
  learnerEmail          String?
  submittedAt           DateTime                 @default(now())
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  course                Course                   @relation(fields: [courseId], references: [id])
  user                  User                     @relation(fields: [userId], references: [id])
  feedbackForm          CourseFeedbackForm       @relation(fields: [feedbackFormId], references: [id])

  @@unique([userId, courseId]) // One submission per user per course
  @@index([courseId])
  @@index([userId])
  @@index([courseId, submittedAt(sort: Desc)])
  @@map("course_feedback_submissions")
}

enum FeedbackOverallRating {
  excellent
  very_good
  good
  fair
  poor
}

model TodoItem {
  id          String   @id @default(uuid())
  title       String?
  content     String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  dueDate     DateTime
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Module {
  id                 String               @id @default(uuid())
  title              String
  description        String
  courseId           String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  chapters           Chapter[]
  course             Course               @relation(fields: [courseId], references: [id])
  UserCourseProgress UserCourseProgress[]
  sections           Section[] // Added this line

  @@map("modules")
}

model Chapter {
  id                 String               @id @default(uuid())
  title              String
  description        String
  pdfFile            String
  moduleId           String
  quizId             String?              @unique
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  LastSeenSection    LastSeenSection[]
  UserCourseProgress UserCourseProgress[]
  module             Module               @relation(fields: [moduleId], references: [id])
  QuizAnswer         QuizAnswer[]
  quizzes            Quiz[]
  sections           Section[]
  QuizProgress       QuizProgress[]

  @@map("chapters")
}

model PoliciesAndProcedures {
  id         String @id @default(uuid())
  policiesId String @unique
  userId     String
  user       User   @relation(fields: [userId], references: [id])
}

model Section {
  id               String            @id @default(uuid())
  title            String
  description      String
  chapterId        String
  moduleId         String? // Added this line
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  shortDescription String?
  
  // New fields for type system
  type             SectionType       @default(DEFAULT)
  orderIndex       Int?              // Order within chapter (1, 2, 3, etc.)
  
  // Match and Learn specific fields (nullable, used when type = MATCH_AND_LEARN)
  itemLabel        String?
  categoryLabel    String?
  categories       String[]          @default([])
  maxPerCategory   Int               @default(1)
  isActive         Boolean           @default(true)
  
  // Visual Activity specific fields (nullable, used when type = VISUAL_ACTIVITY)
  questionText           String?
  imageUrl               String?
  allowMultipleSelection Boolean           @default(false)
  
  // JSON storage for flexible data
  items            Json?  // MATCH_AND_LEARN + ORDERING (orderable rows)
  options          Json?  // VISUAL_ACTIVITY (array of option objects)
  config           Json?  // ORDERING: { correctOrder }; MATCHING: { pairs }

  // ORDERING — orderable items in `items` JSON; correct sequence in `config.correctOrder`
  // MATCHING — `config.pairs` as [{ id, left, right }]; optional `questionText`
  
  LastSeenSection    LastSeenSection[]
  UserCourseProgress UserCourseProgress[]
  chapter            Chapter           @relation(fields: [chapterId], references: [id])
  module             Module?           @relation(fields: [moduleId], references: [id]) // Added this line

  @@map("sections")
}

model UserCourseProgress {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  chapterId String
  sectionId String
  moduleId  String // Added this line
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Chapter   Chapter  @relation(fields: [chapterId], references: [id])
  Course    Course   @relation(fields: [courseId], references: [id])
  Module    Module   @relation(fields: [moduleId], references: [id]) // Added this line
  // FK to Section with cascade delete: when a section is removed, its progress
  // rows go with it. Without this, deleting a section left orphaned progress
  // that still counted toward completion and inflated progress past 100%.
  Section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, chapterId, sectionId])
  // Supports the engagement sweep's MAX(updatedAt) GROUP BY (userId, courseId).
  @@index([userId, courseId, updatedAt])
}

model Quiz {
  id        String   @id @default(uuid())
  question  String   @unique
  options   String[]
  answer    String
  chapterId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter? @relation(fields: [chapterId], references: [id])

  @@map("quizzes")
}

model QuizAnswer {
  id              String   @id @default(uuid())
  quizId          String
  userId          String
  chapterId       String
  answer          String
  isAnswerCorrect Boolean
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Chapter         Chapter  @relation(fields: [chapterId], references: [id])

  @@unique([userId, quizId])
  @@map("quiz_answers")
}

model QuizProgress {
  id              String   @id @default(uuid())
  userId          String
  chapterId       String
  totalAttempts   Int      @default(0) // Tracks the total attempts for this quiz
  isPassed        Boolean  @default(false) // Tracks whether the user passed
  score           Float    @default(0) // Stores the score for the most recent attempt
  passingCriteria Float    @default(0) // Stores the passing percentage for the quiz
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  chapter Chapter @relation(fields: [chapterId], references: [id])

  @@unique([userId, chapterId]) // Ensures one progress entry per user per chapter quiz
  @@map("quiz_progress")
}

model LastSeenSection {
  id        String   @id @default(uuid())
  userId    String
  chapterId String
  moduleId  String
  sectionId String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id])
  // Cascade on section delete so removing a section cleans up its last-seen
  // rows automatically (previously deleted by hand in deleteSection()).
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, chapterId])
  // No (userId, courseId) index existed; required by the engagement sweep's
  // MAX(updatedAt) GROUP BY (userId, courseId) over last-seen activity.
  @@index([userId, courseId, updatedAt])
}

model ForumThread {
  id                  String                @id @default(uuid())
  title               String
  content             String
  userId              String
  courseId            String?
  status              String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  notificationSent    Boolean               @default(false)
  FavoriteForumThread FavoriteForumThread[]
  ForumComment        ForumComment[]
  user                User                  @relation(fields: [userId], references: [id])
  course              Course?               @relation(fields: [courseId], references: [id])
  Notification        Notification[]
  ThreadSubscription  ThreadSubscription[]
  viewEvents          ForumViewEvent[]

  @@map("forum_threads")
}

/// Append-only log: who opened the forum list or viewed a specific thread, when.
model ForumViewEvent {
  id        String          @id @default(uuid())
  userId    String
  threadId  String?         // null = opened forum list (no specific thread)
  courseId  String?
  scope     ForumViewScope  @default(thread)
  createdAt DateTime        @default(now())

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ForumThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  course Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([threadId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("forum_view_events")
}

enum ForumViewScope {
  list
  thread
}

model ForumComment {
  id        String      @id @default(uuid())
  content   String
  userId    String
  threadId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  thread    ForumThread @relation(fields: [threadId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@map("forum_comments")
}

model FavoriteForumThread {
  id        String      @id @default(uuid())
  userId    String
  threadId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  thread    ForumThread @relation(fields: [threadId], references: [id])
  user      User        @relation("UserFavoriteThreads", fields: [userId], references: [id])

  @@unique([userId, threadId])
  @@map("favorite_forum_threads")
}

model ThreadSubscription {
  id        String      @id @default(uuid())
  userId    String
  threadId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  thread    ForumThread @relation(fields: [threadId], references: [id])
  user      User        @relation("UserThreadSubscriptions", fields: [userId], references: [id])

  @@unique([userId, threadId])
  @@map("thread_subscriptions")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  threadId    String?          // nullable; cascade-null when thread is deleted
  message     String           // legacy pre-rendered string — kept until FE fully switches to payload templates
  seenAt      DateTime?        // panel opened (clears bell badge)
  readAt      DateTime?        // row clicked / explicitly marked read; implies seenAt
  payload     Json?            // structured template data — shape varies by type
  groupKey    String?          // collapsed-row key, e.g. "assessment-submitted:<assessmentId>"
  dedupeKey   String?          // per-recipient idempotency key; partial unique on (userId, dedupeKey)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  commenterId String?
  type        NotificationType @default(FORUM_COMMENT)
  referenceId String?          // assessmentId / attemptId / etc. — polymorphic, no FK
  commenter   User?            @relation("Commenter", fields: [commenterId], references: [id])
  thread      ForumThread?     @relation(fields: [threadId], references: [id], onDelete: SetNull)
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([userId, groupKey])
  @@map("notifications")
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String
  courseId  String
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
  course    Course    @relation(fields: [courseId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

model ContactMessage {
  id        String   @id @default(uuid())
  userId    String
  message   String
  isSeen    Boolean  @default(false) // New field to track if the message has been seen by admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("contact_messages")
}

enum Role {
  admin
  user
}

/// File types allowed for assignment submissions
enum AssignmentFileType {
  pdf
  docx
}

/// Lifecycle state of a submission
enum AssignmentSubmissionStatus {
  submitted // Student uploaded, pending review
  in_review // Admin has started reviewing
  approved // Accepted/passed
  rejected // Rejected/failed, may allow resubmission
  returned // Returned with feedback, awaiting resubmission
}

/// Section types for different content formats
enum SectionType {
  DEFAULT
  MATCH_AND_LEARN
  VISUAL_ACTIVITY
  ORDERING
  MATCHING
  @@map("section_type")
}

/// Assignment definition linked to a course
model Assignment {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  instructions       String?
  courseId           String // Required - assignment must belong to a course
  dueAt              DateTime?
  maxPoints          Int?
  allowResubmissions Boolean   @default(true)
  maxAttempts        Int?
  createdByAdminId   String
  assignedToAdminId  String    // Admin who will review submissions for this assignment
  assignmentFileUrl  String?   // Deprecated: first attachment URL (kept for backward compatibility)
  assignmentFileName String?   // Deprecated: first attachment filename
  assignmentFileType AssignmentFileType? // Deprecated: first attachment type
  isActive           Boolean   @default(true) // Admin can deactivate assignments
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  course         Course                 @relation(fields: [courseId], references: [id])
  createdByAdmin User                   @relation("AssignmentsCreatedByAdmin", fields: [createdByAdminId], references: [id])
  submissions    AssignmentSubmission[]
  attachments    AssignmentAttachment[]
  assignedToAdmin User                  @relation("AssignmentReviewer", fields: [assignedToAdminId], references: [id])

  @@index([courseId])
  @@index([createdByAdminId])
  @@index([assignedToAdminId])
  @@index([isActive])
  @@map("assignments")
}

/// Admin-uploaded files attached to an assignment (max 5 per assignment)
model AssignmentAttachment {
  id           String             @id @default(uuid())
  assignmentId String
  fileUrl      String
  fileName     String?
  fileType     AssignmentFileType
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("assignment_attachments")
}

/// A file submission by a student for a specific admin-created assignment
model AssignmentSubmission {
  id                String                     @id @default(uuid())
  assignmentId      String                     // Required - must link to an admin-created assignment
  studentId         String
  assignedToAdminId String                     // Admin who will review this submission
  reviewedByAdminId String?
  fileUrl           String                     // Deprecated: first attachment URL (kept for backward compatibility)
  fileName          String?                    // Deprecated: first attachment filename
  fileType          AssignmentFileType         // Deprecated: first attachment type
  status            AssignmentSubmissionStatus @default(submitted)
  feedback          String?
  score             Float?
  submittedAt       DateTime                   @default(now())
  gradedAt          DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  assignment      Assignment @relation(fields: [assignmentId], references: [id])
  student         User       @relation("StudentSubmissions", fields: [studentId], references: [id])
  assignedToAdmin User       @relation("AdminAssignedSubmissions", fields: [assignedToAdminId], references: [id])
  reviewedByAdmin User?      @relation("AdminReviewedSubmissions", fields: [reviewedByAdminId], references: [id])
  attachments     AssignmentSubmissionAttachment[]

  @@unique([assignmentId, studentId]) // One submission per student per assignment
  @@index([studentId])
  @@index([assignedToAdminId])
  @@index([status])
  @@index([assignmentId])
  @@map("assignment_submissions")
}

/// Student-uploaded files attached to a submission (max 5 per submission)
model AssignmentSubmissionAttachment {
  id           String             @id @default(uuid())
  submissionId String
  fileUrl      String
  fileName     String?
  fileType     AssignmentFileType
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("assignment_submission_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// ASSESSMENT FEATURE
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationType {
  FORUM_COMMENT
  FORUM_THREAD
  ASSESSMENT_SUBMITTED
  ASSESSMENT_GRADED
  ENGAGEMENT_REMINDER // automated low-engagement nudge; reminderType (never_started|stalled) lives in payload
  COURSE_FEEDBACK_REQUIRED // completed course with required feedback not yet submitted
  ASSIGNMENT_CREATED // admin created a new assignment for a course
  ASSIGNMENT_SUBMITTED // student submitted to an assignment; recipient is the assigned reviewer
  ASSIGNMENT_GRADED // admin reviewed/graded a submission; recipient is the student
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_IN_THE_BLANK
  SHORT_ANSWER
  LONG_ANSWER
  ORDERING
  MATCHING
  VISUAL_ACTIVITY
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AssessmentMode {
  MANUAL
  AUTOMATIC
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_GRADED
  GRADED
  FINALIZED
  EXPIRED
}

/// Admin-defined question categories, scoped per course
model QuestionCategory {
  id        String     @id @default(uuid())
  name      String
  courseId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  course    Course     @relation(fields: [courseId], references: [id])
  questions Question[]

  @@unique([courseId, name])
  @@index([courseId])
  @@map("question_categories")
}

/// Question bank — reusable questions per course
/// content JSON shapes:
///   SINGLE_CHOICE:      { options: [{id,text}], correctOptionId: string }
///   MULTIPLE_CHOICE:    { options: [{id,text}], correctOptionIds: string[] }
///   TRUE_FALSE:         { correctAnswer: boolean }
///   FILL_IN_THE_BLANK:  { sentence: string, wordBank: string[], correctAnswer: string }
///   SHORT_ANSWER:       {}
///   LONG_ANSWER:        {}
///   ORDERING:           { items: [{id,text}], correctOrder: string[] }
///   MATCHING:           { pairs: [{id,left,right}] }
///   VISUAL_ACTIVITY:    { imageUrl: string, options: [{id,text,isCorrect}], allowMultiple: boolean }
model Question {
  id                  String             @id @default(uuid())
  courseId            String
  categoryId          String
  type                QuestionType
  difficulty          QuestionDifficulty @default(MEDIUM)
  text                String
  imageUrl            String?
  content             Json
  maxMarks            Float              @default(1)
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  course              Course             @relation(fields: [courseId], references: [id])
  category            QuestionCategory   @relation(fields: [categoryId], references: [id])
  assessmentQuestions AssessmentQuestion[]

  @@index([courseId])
  @@index([courseId, categoryId])
  @@index([courseId, difficulty])
  @@index([courseId, type])
  @@index([isActive])
  @@map("questions")
}

/// Assessment definition linked to a course. Only one may be isActive at a time per course.
/// autoConfig JSON (used when mode = AUTOMATIC):
///   { totalQuestions: number, byCategory: [{categoryId,count}], byDifficulty: [{difficulty,count}] }
model Assessment {
  id                  String         @id @default(uuid())
  courseId            String
  title               String
  description         String?
  mode                AssessmentMode @default(MANUAL)
  isActive            Boolean        @default(false)
  passingPercentage   Float          @default(60)
  timeLimitMinutes    Int?           // informational only — NOT enforced in code yet
  maxAttempts         Int?           // null = unlimited
  autoConfig          Json?          // required when mode = AUTOMATIC
  createdByAdminId    String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  course              Course         @relation(fields: [courseId], references: [id])
  createdByAdmin      User           @relation("AssessmentsCreatedByAdmin", fields: [createdByAdminId], references: [id])
  assessmentQuestions AssessmentQuestion[]
  attempts            AssessmentAttempt[]

  @@index([courseId])
  @@index([courseId, isActive])
  @@index([createdByAdminId])
  @@map("assessments")
}

/// Junction table for MANUAL mode — the ordered list of questions in an assessment
model AssessmentQuestion {
  id            String     @id @default(uuid())
  assessmentId  String
  questionId    String
  orderIndex    Int        @default(0)
  marksOverride Float?     // overrides question.maxMarks for this specific assessment
  createdAt     DateTime   @default(now())
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question      Question   @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("assessment_questions")
}

/// One attempt per student per assessment session. All content is snapshotted at creation time.
model AssessmentAttempt {
  id                   String                  @id @default(uuid())
  assessmentId         String
  userId               String
  status               AssessmentAttemptStatus @default(IN_PROGRESS)
  // Snapshot of assessment settings at attempt creation time
  snapshotTitle        String
  snapshotPassingPct   Float
  snapshotMaxAttempts  Int?
  snapshotTimeLimitMin Int?
  // Scoring (populated progressively and on submission/finalization)
  totalMarks           Float?
  marksObtained        Float?
  percentage           Float?
  isPassed             Boolean?
  // Lifecycle timestamps
  startedAt            DateTime               @default(now())
  submittedAt          DateTime?
  gradedAt             DateTime?
  finalizedAt          DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  assessment           Assessment             @relation(fields: [assessmentId], references: [id])
  user                 User                   @relation(fields: [userId], references: [id])
  questionSnapshots    AttemptQuestionSnapshot[]
  courseCompletion     CourseCompletion?       @relation("BestAttempt")

  @@index([assessmentId])
  @@index([userId])
  @@index([userId, assessmentId])
  @@index([status])
  @@map("assessment_attempts")
}

/// Full snapshot of a single question within an attempt, plus student answer and grading state.
/// studentAnswer JSON shapes:
///   SINGLE_CHOICE:      { selectedOptionId: string }
///   MULTIPLE_CHOICE:    { selectedOptionIds: string[] }
///   TRUE_FALSE:         { answer: boolean }
///   FILL_IN_THE_BLANK:  { selectedWord: string }
///   SHORT_ANSWER:       { text: string }
///   LONG_ANSWER:        { text: string }
///   ORDERING:           { orderedIds: string[] }
///   MATCHING:           { pairs: [{leftId,rightId}] }
///   VISUAL_ACTIVITY:    { selectedOptionIds: string[] }
model AttemptQuestionSnapshot {
  id               String            @id @default(uuid())
  attemptId        String
  questionId       String            // traceability only — question may be edited/deleted later
  orderIndex       Int               @default(0)
  // Snapshot of question content at attempt creation time
  questionType     QuestionType
  questionText     String
  questionImageUrl String?
  questionContent  Json              // full content snapshot (correct answers included for grading)
  maxMarks         Float
  // Student answer
  studentAnswer    Json?
  isAnswered       Boolean           @default(false)
  isLocked         Boolean           @default(false) // locked once answered — cannot re-answer
  // Grading
  systemScore      Float?            // auto-calculated on answer submission
  adminScore       Float?            // admin override or manual grade
  finalScore       Float?            // adminScore ?? systemScore, set on finalization
  adminFeedback    String?
  gradedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attempt          AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
  @@index([attemptId, isAnswered])
  @@map("attempt_question_snapshots")
}

/// Tracks full course completion (course content + assessment passed) per user per course.
model CourseCompletion {
  id                 String             @id @default(uuid())
  userId             String
  courseId           String
  isPassed           Boolean            @default(false)
  bestAttemptId      String?            @unique
  certificateUrl     String?
  courseCompletedAt  DateTime?
  assessmentPassedAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id])
  course             Course             @relation(fields: [courseId], references: [id])
  bestAttempt        AssessmentAttempt? @relation("BestAttempt", fields: [bestAttemptId], references: [id])

  @@unique([userId, courseId])
  @@index([userId, courseId])
  @@index([userId, isPassed])
  @@map("course_completions")
}

// ── Platform tracking ────────────────────────────────────────────────────────

/// Append-only log: one row per successful login. Captures when, from where
/// (IP), and with what client (user-agent). Never updated.
model LoginEvent {
  id        String   @id @default(uuid())
  userId    String
  /// Client IP, best-effort from x-forwarded-for (Vercel) / socket. Nullable
  /// because a proxy may strip it. Stored as text (supports IPv4 + IPv6).
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Report hot path: a user's logins newest-first; and global "who logged in".
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("login_events")
}

/// Running total of active time a user has spent in a single section (lesson),
/// accumulated from heartbeat pings. chapterId/moduleId/courseId are denormalized
/// so reports can roll time up to any level without extra joins.
model SectionTimeSpent {
  id              String   @id @default(uuid())
  userId          String
  sectionId       String
  chapterId       String
  moduleId        String?
  courseId        String
  /// Sum of capped heartbeat intervals — the student's active seconds here.
  totalSeconds    Int      @default(0)
  /// Last ping time; used to compute the next contiguous interval and to cap
  /// gaps (idle/closed tab) so time can't be inflated.
  lastHeartbeatAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One running total per user per section.
  @@unique([userId, sectionId])
  // Roll-up report paths.
  @@index([userId, courseId])
  @@index([courseId, moduleId])
  @@index([userId, chapterId])
  @@map("section_time_spent")
}

/// Daily roll-up of active seconds per user per course (UTC calendar day).
/// Written alongside section_time_spent heartbeats for admin time breakdowns.
model SectionTimeSpentDaily {
  id           String   @id @default(uuid())
  userId       String
  courseId     String
  day          DateTime @db.Date
  totalSeconds Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, day])
  @@index([userId, day])
  @@index([day])
  @@map("section_time_spent_daily")
}

enum EmailType {
  ENGAGEMENT_REMINDER
  PASSWORD_RESET
  WELCOME // sent when a user self-registers
  CONTACT_MESSAGE // a "contact us" message, emailed to the admin
  COURSE_COMPLETED // congratulations when a user completes a course
  FEEDBACK_REQUEST // ask a user to fill the course feedback form
  FEEDBACK_REMINDER // periodic nudge for pending required feedback
  FEEDBACK_OUTSTANDING // one-off backfill: completed course, feedback not submitted
  FEEDBACK_RECEIVED // confirm to the user their feedback was registered
  FEEDBACK_RECEIVED_ADMIN // notify the admin of a new feedback submission
  // Notification mirror emails — one per in-app NotificationType.
  NOTIFICATION_FORUM_THREAD
  NOTIFICATION_FORUM_COMMENT
  NOTIFICATION_ASSESSMENT_SUBMITTED
  NOTIFICATION_ASSESSMENT_GRADED
  NOTIFICATION_ASSIGNMENT_CREATED
  NOTIFICATION_ASSIGNMENT_SUBMITTED
  NOTIFICATION_ASSIGNMENT_GRADED
}

enum EmailStatus {
  SENT // accepted by the provider
  FAILED // provider rejected or threw
  SKIPPED // mail disabled (no API key) — recorded so dev/test gaps are visible
}

/// Audit trail of every transactional email the system attempts to send. Written
/// best-effort by MailService on each send (success, failure, or skipped) so the
/// admin dashboard can answer "who did/didn't get the low-engagement email and
/// did it deliver". userId is nullable (recipient may not resolve to a user).
model EmailLog {
  id         String      @id @default(uuid())
  userId     String?
  recipient  String // email address the message was addressed to
  type       EmailType
  status     EmailStatus
  providerId String? // Resend message id when sent
  error      String? // failure/skip reason
  metadata   Json? // type-specific context, e.g. { reminderType, courseId }
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("email_logs")
}

enum SecurityEventType {
  PASSWORD_RESET_COMPLETED // via forgot-password OTP flow
  PASSWORD_CHANGED_FIRST_LOGIN // forced change on first login (admin-created acct)
  PASSWORD_CHANGED // authenticated self-service change
}

/// Audit trail of security-sensitive account events (password changes/resets).
/// Written on every password-change path so the admin dashboard can report who
/// changed their password, when, and how.
model SecurityEvent {
  id        String            @id @default(uuid())
  userId    String
  type      SecurityEventType
  /// Who performed the action: the user themselves, or an admin id when
  /// admin-initiated. Null when unknown (e.g. unauthenticated reset flow).
  actorId   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@map("security_events")
}
