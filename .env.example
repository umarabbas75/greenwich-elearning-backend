# Neon on Vercel: pooled URL for the app (*-pooler* host), direct URL for Prisma migrations.
# Mirror DATABASE_URL (and DIRECT_DATABASE_URL) in Vercel → Settings → Environment Variables for Production *and* Preview.
# Example pooled: postgresql://USER:PASS@YOUR_BRANCH-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=5&pool_timeout=15&connection_limit=1
# Example direct (non-pooler host): postgresql://USER:PASS@YOUR_BRANCH.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=<pooled db connection url>
DIRECT_DATABASE_URL=<direct db connection url (same db, no -pooler host)>
PORT=<app port>
JWT_SECRET=<jwt secret>
JWT_EXPIRY=<jwt expiry>
# Optional comma-separated emails that bypass chapter sequencing (mirrors frontend free-roam allowlist)
FREE_ROAM_EMAILS=

# ── Engagement reminders ───────────────────────────────────────────────────
# Transactional email (Resend). Domain greenwichtc-elearning.com is verified.
RESEND_API_KEY=
MAIL_FROM=Greenwich Training & Consulting <noreply@greenwichtc-elearning.com>
# Public app base URL used to build course deep links in reminder emails.
APP_BASE_URL=https://www.greenwichtc-elearning.com
# Shared secret for the cron-triggered sweep endpoint. Set the SAME value as the
# Vercel project's CRON_SECRET env var — Vercel Cron sends it as a Bearer token.
CRON_SECRET=
# Thresholds (days). Defaults applied if unset: never-started=3, stalled=7.
ENGAGEMENT_NEVER_STARTED_DAYS=3
ENGAGEMENT_STALLED_DAYS=7
# Cooldown windows (days) — at most one reminder per user/course/type per window.
ENGAGEMENT_NEVER_STARTED_COOLDOWN_DAYS=3
ENGAGEMENT_STALLED_COOLDOWN_DAYS=7
# Max candidate rows processed per reminder type per cron run (serverless bound).
ENGAGEMENT_BATCH_LIMIT=50
# Emails sent per ~1s batch. Resend's limit is 2 req/s — keep at 2 (or 1).
# The sweep pauses ~1.1s between batches and retries rate-limited sends once.
ENGAGEMENT_EMAIL_CONCURRENCY=2