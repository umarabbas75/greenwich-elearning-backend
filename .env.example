# Neon on Vercel: pooled URL for the app (*-pooler* host), direct URL for Prisma migrations.
# Mirror DATABASE_URL (and DIRECT_DATABASE_URL) in Vercel → Settings → Environment Variables for Production *and* Preview.
# Example pooled: postgresql://USER:PASS@YOUR_BRANCH-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=5&pool_timeout=15&connection_limit=1
# Example direct (non-pooler host): postgresql://USER:PASS@YOUR_BRANCH.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=<pooled db connection url>
DIRECT_DATABASE_URL=<direct db connection url (same db, no -pooler host)>
PORT=<app port>
JWT_SECRET=<jwt secret>
JWT_EXPIRY=<jwt expiry>
# Optional comma-separated emails that bypass chapter sequencing (mirrors frontend free-roam allowlist)
FREE_ROAM_EMAILS=